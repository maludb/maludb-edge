RewriteEngine On
RewriteRule (^|/)(?:var|runtime|bin|config|database|src|source|test|tests|vendor)(/|$) - [F,L]
RewriteRule (^|/)(?:composer\.(?:json|lock)|\.env(?:\..*)?|test-connection\.php)$ - [F,L]
RewriteRule (^|/).*\.(?:sqlite|sqlite3|db)(?:-(?:wal|shm|journal))?$ - [F,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
